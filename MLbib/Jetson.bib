@article{Sun:2020,
  author   = {Sun, Peiyi and Bisschop, Roeland and Niu, Huichang and Huang, Xinyan},
  title    = {A Review of Battery Fires in Electric Vehicles},
  doi      = {10.1007/s10694-019-00944-3},
  id       = {Sun2020},
  isbn     = {1572-8099},
  journal  = {Fire Technology},
  number   = {4},
  pages    = {1361--1410},
  url      = {https://doi.org/10.1007/s10694-019-00944-3},
  volume   = {56},
  year     = {2020},
  abstract = {Over the last decade, the electric vehicle (EV) has significantly changed the car industry globally, driven by the fast development of Li-ion battery technology. However, the fire risk and hazard associated with this type of high-energy battery has become a major safety concern for EVs. This review focuses on the latest fire-safety issues of EVs related to thermal runaway and fire in Li-ion batteries. Thermal runaway or fire can occur as a result of extreme abuse conditions that may be the result of the faulty operation or traffic accidents. Failure of the battery may then be accompanied by the release of toxic gas, fire, jet flames, and explosion. This paper is devoted to reviewing the battery fire in battery EVs, hybrid EVs, and electric buses to provide a qualitative understanding of the fire risk and hazards associated with battery powered EVs. In addition, important battery fire characteristics involved in various EV fire scenarios, obtained through testing, are analysed. The tested peak heat release rate (PHHR in MW) varies with the energy capacity of LIBs ({\$}{\$}E{\_}{\{}B{\}}{\$}{\$}in Wh) crossing different scales as {\$}{\$}PHRR = 2E{\_}{\{}B{\}}\^{}{\{}0.6{\}}{\$}{\$}. For the full-scale EV fire test, limited data have revealed that the heat release and hazard of an EV fire are comparable to that of a fossil-fuelled vehicle fire. Once the onboard battery involved in fire, there is a greater difficulty in suppressing EV fires, because the burning battery pack inside is inaccessible to externally applied suppressant and can re-ignite without sufficient cooling. As a result, an excessive amount of suppression agent is needed to cool the battery, extinguish the fire, and prevent reignition. By addressing these concerns, this review aims to aid researchers and industries working with batteries, EVs and fire safety engineering, to encourage active research collaborations, and attract future research and development on improving the overall safety of future EVs. Only then will society achieve the same comfort level for EVs as they have for conventional vehicles.},
}

@article{Sunanda:2020,
  author    = {Sunanda, N. and Raju, S. Hrushikesava and  Waris, Saiyed Faiayaz and  Koulagaji, Ashok},
  doi       = {10.1088/1757-899X/981/2/022066},
  url       = {https://dx.doi.org/10.1088/1757-899X/981/2/022066},
  year      = {2020},
  month     = {dec},
  publisher = {IOP Publishing},
  volume    = {981},
  number    = {2},
  pages     = {022066},
  title     = {Smart Instant Charging of Power Banks},
  journal   = {IOP Conference Series: Materials Science and Engineering},
  abstract  = {Nowadays, charging portable devices like mobile devices through power banks is very common and is required. In this paper, the drawbacks of existing power banks are discussed and are required to upgrade with novel and reliable technology. The mobile devices need to be recharged whenever its charging is completed, that’s why power banks came into the market to recharge portable devices such as mobile devices. As the load increases, the charging will be degraded and needs to be charged. The charging phenomenon that existing power banks use is time-consuming. The factor time plays an important role in modern days because many activities need to be done at that time. The scheduled activities to be disturbed because of the lack of charging while involved in traveling for long hours and the days. When there is a technology added in the power banks where the portable devices are charged instantly by scanning the power bank charged code using recipient mobile (Portable device). The charging of the portable device is done in nanoseconds. This greatly reduces the amount of time spent on charging over portable devices using existing power banks. Functionality and performance are demonstrated in the proposed and results chapter. In this, the amount of charging is also to be customized so that the leftover charging in the power bank to be used for charging the other portable device.}
}


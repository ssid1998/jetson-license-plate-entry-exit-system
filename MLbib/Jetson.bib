@misc{Rui:2018,
  author      = {Rui Zhu and Shifeng Zhang and Xiaobo Wang and Longyin Wen and Hailin Shi and Liefeng Bo and Tao Mei},
  title       = {ScratchDet: Exploring to Train Single-Shot Object Detectors from Scratch},
  doi         = {10.48550/ARXIV.1810.08425},  
  volume      = {abs/1810.08425},
  year        = {2018},
  url         = {http://arxiv.org/abs/1810.08425},
  publisher   = {arXiv},
  eprinttype  = {arXiv},
  eprint      = {1810.08425},
  timestamp   = {Mon, 01 Feb 2021 18:33:22 +0100},
  keywords    = {Single shot multi-box detector (SSMB), Faster region convolutional neural networks (F-CNN), Loss function, Aspect ratio}, 
  biburl      = {https://dblp.org/rec/journals/corr/abs-1810-08425.bib},
  bibsource   = {dblp computer science bibliography, https://dblp.org},
  Description = {In this article, they determine the way to train object detectors from scratch in a sound way. They started by analysing the previous work on optimization landscape, they found that one of the overlooked points in current trained-from-scratch detector is the BatchNorm. By relying on the stable and predictable gradients of BatchNorm, they trained the detector stably from the beginning while maintaining good performance regardless of the network architecture. Taking this as an advantage, they were able to explore different kinds of networks for object detection, without suffering from the backlash of poor convergence. Through extensive experimentation and analysis on downsampling factors, they have proposed the Root-ResNet backbone network, which makes the most of the information contained in the original image. Thier ScratchDet achieved state-of-the-art accuracy among all train-from-scratch detectors on PASCAL VOC 2007, 2012, and MS COCO, even better than some single-stage pre-trained methods.}
}

